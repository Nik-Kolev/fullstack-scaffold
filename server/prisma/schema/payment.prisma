enum PaymentStatus {
    PENDING
    SUCCEEDED
    FAILED
    REFUNDED
    PARTIALLY_REFUNDED
    DISPUTED
}

model Payment {
    id                    String        @id @default(cuid())
    userId                Int           @map("user_id")
    user                  User          @relation(fields: [userId], references: [id])
    stripeSessionId       String        @unique @map("stripe_session_id")
    stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
    amountTotal           Int           @map("amount_total")
    quantity              Int           @default(1)
    currency              String
    status                PaymentStatus @default(PENDING)
    description           String?
    metadata              Json?
    refundedAt            DateTime?     @map("refunded_at")
    refundedAmountTotal   Int?          @map("refunded_amount_total")
    createdAt             DateTime      @default(now()) @map("created_at")

    @@map("payments")
}

// Stripe redelivers an event on any non-2xx response. The status guards in paymentService
// make today's handlers naturally idempotent, but anything that increments or credits would
// double-apply on a retry — this makes the guarantee explicit rather than incidental.
model ProcessedStripeEvent {
    eventId     String   @id @map("event_id")
    type        String
    processedAt DateTime @default(now()) @map("processed_at")

    @@map("processed_stripe_events")
}
