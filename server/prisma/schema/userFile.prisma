model UserFile {
    key          String   @id
    userId       Int      @map("user_id")
    url          String
    originalName String
    mimeType     String
    size         Int
    folder       String
    createdAt    DateTime @default(now()) @map("created_at")
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("user_files")
}
