model RefreshToken {
    refreshTokenId String    @id @map("refresh_token_id")
    userId         Int       @map("user_id")
    expiresAt      DateTime  @map("expires_at")
    createdAt      DateTime  @default(now()) @map("created_at")
    // Rotation marks the row instead of deleting it, so a second tab presenting the same
    // token inside the grace window can be handed the successor rather than logged out.
    rotatedAt      DateTime? @map("rotated_at")
    replacedById   String?   @map("replaced_by_id")
    user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([rotatedAt])
    @@map("refresh_tokens")
}
